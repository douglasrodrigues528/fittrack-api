{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    
    "declaration": true,
    "removeComments": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    
    "sourceMap": true,

    "outDir": "./dist",
    "incremental": true,

    "skipLibCheck": true,

    "strict": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node", "jest"]
  }
}